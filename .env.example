# ── Softimmo configuration ──────────────────────────────────────────────
# Copy to .env and adjust. No secrets are committed.

# Server
PORT=8787
HOST=127.0.0.1
NODE_ENV=development
# If you change PORT above, set this to the same value so the Vite dev proxy
# (web → API) targets the right port. Defaults to 8787.
SOFTIMMO_API_PORT=8787

# Database
DB_PATH=./data/softimmo.db

# Python
# Path to the python executable inside the project venv.
# Windows: python/.venv/Scripts/python.exe   Unix: python/.venv/bin/python
PYTHON_BIN=python/.venv/Scripts/python.exe

# Engine politeness / crawling
CRAWL_CONCURRENCY=4
CRAWL_PER_DOMAIN_DELAY_MS=1500
CRAWL_TIMEOUT_MS=15000
CRAWL_USER_AGENT=SoftimmoBot/0.1 (+local research tool)
RESPECT_ROBOTS=false
SMTP_PROBE_ENABLED=false

# AI layer (optional — leave empty to disable Claude features)
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
AI_ENABLED=false
AI_MAX_TOKENS=1024

# Optional free-tier search key (Marketplace, optional)
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
